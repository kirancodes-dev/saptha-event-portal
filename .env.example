# =========================================================
# .env.example — Copy to .env and fill in your values
# DO NOT commit .env to version control
# =========================================================

# =========================================================
# 1. FLASK ENVIRONMENT
# =========================================================
# Set to 'production' when deploying live
FLASK_ENV=development

# =========================================================
# 2. SECURITY
# =========================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# This should be a random 64-character hex string
SECRET_KEY=your_random_secret_key_here_64_chars_minimum

# =========================================================
# 3. FIREBASE — CRITICAL FOR PRODUCTION
# =========================================================
# Get this from Firebase Console → Project Settings → Service Accounts
# It's a JSON file content. Copy entire JSON as single line
# OR set FIREBASE_KEY_PATH to local path (dev only)
FIREBASE_CREDENTIALS={"type":"service_account","project_id":"...","key_id":"..."}
FIREBASE_KEY_PATH=serviceAccountKey.json

# =========================================================
# 4. SUPERADMIN CREDENTIALS — CHANGE IMMEDIATELY AFTER FIRST LOGIN!
# =========================================================
# Run: python init_superadmin.py to create the account
SUPER_ADMIN_EMAIL=admin@snpsu.edu.in
SUPER_ADMIN_PASS=Saptha@Admin2026
MASTER_SECRET_KEY=SAPTHA@2026

# =========================================================
# 5. EMAIL CONFIGURATION — Required for notifications
# =========================================================
# Gmail App Password (NOT your Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
MAIL_USER=sapthhack@gmail.com
MAIL_PASS=your_16_char_gmail_app_password_here
MAIL_TIMEOUT=10

# =========================================================
# 6. RATE LIMITING — Adjust based on usage patterns
# =========================================================
# Format: "requests per period;requests per period"
RATELIMIT_DEFAULT=500 per day;100 per hour

# For Redis-backed rate limiting (optional)
# REDIS_URL=redis://:password@host:port/database
# If not set, uses in-memory storage (slower, not recommended for production)

# =========================================================
# 7. TWILIO — OPTIONAL: For WhatsApp notifications
# =========================================================
# Get from: https://www.twilio.com/console
# App works without these — WhatsApp sends are skipped
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# =========================================================
# 8. GEMINI AI — OPTIONAL: For AI chatbot features
# =========================================================
# Get from: https://makersuite.google.com/app/apikey
# If not set, chatbot features are disabled
GEMINI_API_KEY=your_gemini_api_key_here

# =========================================================
# 9. DEPLOYMENT URLs
# =========================================================
# Set to production URL when deploying
BASE_URL=http://127.0.0.1:5000
COLLEGE_LOGO_URL=https://snpsu.edu.in/wp-content/uploads/2024/03/Untitled-2-1-1536x527.png

# =========================================================
# 10. DATABASE BACKUPS — OPTIONAL: For Firestore exports
# =========================================================
# Configure in Firebase Console → Firestore → Backups
# Enable automated daily backups for production
# FIRESTORE_BACKUP_BUCKET=gs://your-backup-bucket

# =========================================================
# 11. ERROR TRACKING — OPTIONAL: For production monitoring
# =========================================================
# Sentry DSN for error tracking
# Get from: https://sentry.io
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# =========================================================
# 12. LOGGING LEVEL
# =========================================================
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =========================================================
# DEPLOYMENT PLATFORMS: Railway / Render / Heroku
# =========================================================
# For Railway:
#   - Go to your project → Variables
#   - Click "Raw editor"
#   - Paste all the above settings
#
# For Render:
#   - Go to your service → Environment
#   - Add each variable individually
#
# For Heroku:
#   - Run: heroku config:set KEY1=value1 KEY2=value2 ...
#   - Or use Heroku Dashboard → Settings → Config Vars
